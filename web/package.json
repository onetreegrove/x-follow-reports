{
  "name": "x-follow-report-browser",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "start": "node server-dist/index.js",
    "build": "vue-tsc --noEmit && vite build && pnpm build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=server-dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "markdown-it": "^14.1.0",
    "sanitize-html": "^2.13.1",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/sanitize-html": "^2.13.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.2.0"
  },
  "workspaces": [
    "."
  ]
}
